{
  "version": 2,
  "workflow_inventory": {
    "version": 1,
    "managed_workflows": [
      {
        "id": "build-release-artifacts",
        "source": "shared/bijux-gh/workflows/build-release-artifacts.yml",
        "consumer_runtime": ".github/workflows/build-release-artifacts.yml"
      },
      {
        "id": "deploy-docs",
        "source": "shared/bijux-gh/workflows/deploy-docs.yml",
        "consumer_runtime": ".github/workflows/deploy-docs.yml"
      },
      {
        "id": "github-policy",
        "source": "shared/bijux-gh/workflows/github-policy.yml",
        "consumer_runtime": ".github/workflows/github-policy.yml"
      },
      {
        "id": "release-artifacts",
        "source": "shared/bijux-gh/workflows/release-artifacts.yml",
        "consumer_runtime": ".github/workflows/release-artifacts.yml"
      },
      {
        "id": "release-crates",
        "source": "shared/bijux-gh/workflows/release-crates.yml",
