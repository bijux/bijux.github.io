      "dependabot": {
        "version": 2,
        "updates": [
          {
            "package-ecosystem": "cargo",
            "directory": "/",
            "schedule": {
              "interval": "weekly",
              "day": "monday",
              "time": 18000
            },
            "open-pull-requests-limit": 3,
            "commit-message": {
              "prefix": "chore(deps)"
            },
            "groups": {
              "rust-minor-patch": {
                "update-types": [
                  "minor",
                  "patch"
                ]
              },
              "rust-major": {
                "update-types": [
                  "major"
                ]
              }
            }
          },
          {
            "package-ecosystem": "github-actions",
            "directory": "/",
            "schedule": {
              "interval": "weekly",
              "day": "monday",
              "time": 19800
            },
            "open-pull-requests-limit": 3,
            "commit-message": {
              "prefix": "chore(actions)"
            },
            "groups": {
              "github-actions-minor-patch": {
                "update-types": [
                  "minor",
                  "patch"
                ]
              },
              "github-actions-major": {
                "update-types": [
                  "major"
                ]
              }
            }
          },
          {
            "package-ecosystem": "npm",
            "directory": "/configs/sources/repository/docs",
            "schedule": {
              "interval": "weekly",
              "day": "monday",
              "time": 21600
            },
            "open-pull-requests-limit": 3,
            "commit-message": {
              "prefix": "chore(docs-deps)"
            },
            "groups": {
              "docs-tooling-minor-patch": {
                "update-types": [
                  "minor",
                  "patch"
                ]
              },
              "docs-tooling-major": {
                "update-types": [
                  "major"
                ]
              }
            }
          },
          {
            "package-ecosystem": "pip",
            "directory": "/configs/sources/repository/docs",
            "schedule": {
              "interval": "weekly",
              "day": "monday",
              "time": 22500
            },
            "open-pull-requests-limit": 3,
            "commit-message": {
              "prefix": "chore(docs-python)"
            },
            "groups": {
              "docs-python-minor-patch": {
                "update-types": [
                  "minor",
                  "patch"
                ]
              },
              "docs-python-major": {
                "update-types": [
                  "major"
                ]
              }
            }
          }
        ]
      },
      "workflow_wrappers": {
        "ci": {
          "name": "CI",
          "true": {
            "push": {
              "branches": [
                "main"
              ],
              "tags": [
                "v*"
              ]
            },
            "pull_request": null
          },
          "concurrency": {
            "group": "${{ github.workflow }}-${{ github.ref }}",
            "cancel-in-progress": true
          },
          "permissions": {
            "contents": "read"
          },
          "jobs": {
            "run": {
              "uses": "./.github/workflows/reusable-ci-rust-stack.yml",
              "with": {
                "rust_toolchain_version": "1.86.0",
                "enable_python_toolchain": false,
                "test_python_versions": "[\"3.11\"]",
                "use_isolated_temp_roots": true,
                "security_cargo_target_dir": "${{ github.workspace }}/.cache/cargo/target/security",
                "security_cargo_home": "${{ github.workspace }}/.cache/cargo/home/security",
                "security_tmp_relative": "artifacts/isolates/security/tmp",
                "test_cargo_target_dir": "${{ github.workspace }}/.cache/cargo/target/test",
                "test_cargo_home": "${{ github.workspace }}/.cache/cargo/home/test",
                "test_tmp_relative": "artifacts/isolates/test/tmp",
                "install_test_tools_command": "make gh-test-install-rust-tools",
                "expose_cargo_bin_path": true,
                "fmt_command": "make gh-fmt",
                "lint_command": "make gh-lint",
                "security_command": "make gh-security",
                "test_command": "make gh-test"
              }
            }
          }
        }
      },
      "workflow_allowlist": [
        "deploy-docs",
        "github-policy",
        "release-crates",
        "release-github",
        "reusable-ci-rust-stack"
      ],
      "pinned_std_sha": "1f69262f891f11a8fb5ea49ddd4477977228e776"
    },
