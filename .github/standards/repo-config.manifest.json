      "release_env": [],
      "dependabot": {
        "version": 2,
        "updates": [
          {
            "package-ecosystem": "github-actions",
            "directory": "/",
            "schedule": {
              "interval": "weekly"
            },
            "open-pull-requests-limit": 10,
            "labels": [
