# Optional repository-local overrides for .github/workflows/deploy-docs.yml.
# Copy to .github/docs-deploy.env in a consuming repository only when defaults do not fit.

# BIJUX_DOCS_SITE_URL=https://bijux.io/example/
# BIJUX_DOCS_SITE_DIR=artifacts/docs/site

# Explicit commands override auto-discovery.
# BIJUX_DOCS_INSTALL_COMMAND=make gh-docs-install
# BIJUX_DOCS_BUILD_COMMAND=make docs-check
# BIJUX_DOCS_VERIFY_COMMAND=make gh-docs-verify

# Toolchain switches: true or false.
# BIJUX_DOCS_SETUP_PYTHON=true
# BIJUX_DOCS_SETUP_UV=false
# BIJUX_DOCS_SETUP_NODE=false
# BIJUX_DOCS_SETUP_RUST=false

# Toolchain versions.
# BIJUX_DOCS_PYTHON_VERSION=3.11
# BIJUX_DOCS_NODE_VERSION=22
# BIJUX_DOCS_RUST_TOOLCHAIN=stable
